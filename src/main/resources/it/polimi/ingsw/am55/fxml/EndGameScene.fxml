<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.polimi.ingsw.am55.view.gui.scene.EndGameSceneController"
            stylesheets="@../css/gui.css"
            styleClass="root-pane">
    <top>
        <VBox spacing="8" styleClass="header-pane">
            <padding>
                <Insets top="18" right="24" bottom="14" left="24" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="titleLabel" text="Fine partita" styleClass="main-title-small" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Refresh" onAction="#onRefreshClick" />
            </HBox>
            <Label fx:id="statusLabel" styleClass="info-text" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="18" styleClass="board-pane">
                    <padding>
                        <Insets top="20" right="28" bottom="28" left="28" />
                    </padding>

                    <VBox spacing="8" styleClass="card-panel">
                        <Label text="Vincitore/i" styleClass="section-title" />
                        <VBox fx:id="winnersBox" spacing="6" />
                    </VBox>

                    <VBox spacing="8" styleClass="card-panel">
                        <Label text="Effetti finali" styleClass="section-title" />
                        <VBox fx:id="effectsBox" spacing="6" />
                    </VBox>

                    <VBox spacing="8" styleClass="card-panel">
                        <Label text="Eventi finali risolti" styleClass="section-title" />
                        <VBox fx:id="finalEventsBox" spacing="6" />
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
