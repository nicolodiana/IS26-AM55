<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.polimi.ingsw.am55.view.gui.scene.GameSceneController"
            stylesheets="@../css/gui.css"
            styleClass="root-pane game-root">

    <!-- TOP: header invariato -->
    <top>
        <VBox spacing="8" styleClass="header-pane">
            <padding>
                <Insets top="14" right="18" bottom="12" left="18" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="AM55 - Board" styleClass="main-title-small" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Quit" onAction="#onQuitClick" styleClass="danger-button" />
            </HBox>
            <HBox spacing="18" alignment="CENTER_LEFT">
                <Label fx:id="gameIdLabel" />
                <Label fx:id="stateLabel" />
                <Label fx:id="roundLabel" />
                <Label fx:id="currentPlayerLabel" />
            </HBox>
            <Label fx:id="instructionLabel" wrapText="true" styleClass="instruction-text" />
            <Label fx:id="statusLabel" wrapText="true" styleClass="info-text" />
        </VBox>
    </top>

    <!-- CENTER: SplitPane — trascina il divisore per ridimensionare -->
    <center>
        <SplitPane dividerPositions="0.25">

            <!-- PANNELLO SINISTRO: giocatori + turn ticket + eventi -->
            <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="12" styleClass="side-panel">
                        <padding>
                            <Insets top="16" right="14" bottom="16" left="16" />
                        </padding>
                        <Label text="Giocatori" styleClass="section-title" />
                        <VBox fx:id="playersBox" spacing="8" />

                        <Label text="Turn ticket" styleClass="section-title" />
                        <ScrollPane fitToHeight="true" fitToWidth="false"
                                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
                            <content>
                                <HBox fx:id="turnTicketBox" spacing="10" alignment="CENTER_LEFT" />
                            </content>
                        </ScrollPane>

                        <ScrollPane fx:id="eventsScrollPane" fitToWidth="true"
                                    visible="false" managed="false">
                            <content>
                                <VBox fx:id="eventsBox" spacing="8" />
                            </content>
                        </ScrollPane>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- PANNELLO DESTRO: board con scroll sia orizzontale che verticale -->
            <ScrollPane fitToWidth="false" fitToHeight="false"
                        hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="16" styleClass="board-pane">
                        <padding>
                            <Insets top="16" right="18" bottom="18" left="18" />
                        </padding>

                        <VBox spacing="8">
                            <Label text="Bidding Trail" styleClass="section-title" />
                            <HBox fx:id="biddingTrailBox" spacing="12" alignment="CENTER_LEFT" />
                        </VBox>

                        <VBox spacing="8">
                            <Label text="UPPER ROW" styleClass="section-title" />
                            <HBox fx:id="upperRowBox" spacing="12" alignment="CENTER_LEFT" />
                        </VBox>

                        <VBox spacing="8">
                            <Label text="LOWER ROW" styleClass="section-title" />
                            <HBox fx:id="lowerRowBox" spacing="12" alignment="CENTER_LEFT" />
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

        </SplitPane>
    </center>

</BorderPane>
